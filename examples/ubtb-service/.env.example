# =============================================================
# Environment Variables for UBTB Service Example
# =============================================================
# Copy this file to .env and fill in your values.
# DO NOT commit .env to git (it is already in .gitignore).

# --- Application ---
BASE_URL=http://127.0.0.1:8080           # UBTB backend base URL

# --- Test Credentials ---
TEST_EMAIL=admin@ubtb.com                # Login email
TEST_PASSWORD=                            # Login password (REQUIRED)

# --- Remote Deployment (for ops/deploy.py) ---
DEPLOY_HOST=                              # SSH host of test server (e.g., 192.168.1.100)
DEPLOY_USER=                              # SSH username
DEPLOY_PASSWORD=                          # SSH password
DEPLOY_SUDO_PASSWORD=                     # Sudo password (defaults to DEPLOY_PASSWORD)
DEPLOY_REMOTE_BASE=/home/user/ubtb-project  # Remote project path

# --- Local Paths (for ops/deploy.py upload) ---
LOCAL_PROJECT_DIR=                        # Local path to UBTB project source
LOCAL_TEST_ASSETS_DIR=                    # Local path to test assets directory
