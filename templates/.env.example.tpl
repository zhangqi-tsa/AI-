# =============================================================
# Environment Variables for {SERVICE_NAME} Example
# =============================================================
# Copy this file to .env and fill in your values.
# DO NOT commit .env to git (it is already in .gitignore).

# --- Application ---
BASE_URL=http://127.0.0.1:8080           # Service base URL

# --- Test Credentials ---
TEST_USERNAME=admin@example.com           # Login username/email
TEST_PASSWORD=                             # Login password (REQUIRED)

# --- Deployment (optional, for ops/deploy.py) ---
# DEPLOY_HOST=                             # SSH host of test server
# DEPLOY_USER=                             # SSH username
# DEPLOY_PASSWORD=                         # SSH password
# DEPLOY_REMOTE_BASE=/home/user/project    # Remote project path

# --- Framework ---
# KEPLOY_TOOLS_DIR=                        # Path to ai-keploy-test-assets repo root (if using multi-repo setup)
